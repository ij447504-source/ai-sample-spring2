{{> layout/header}}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 style="font-weight: 700;">게시글 목록</h2>
        <a href="/board/save-form" class="btn btn-primary" style="border-radius: var(--radius-sm);">글쓰기</a>
    </div>

    <div class="card shadow-sm" style="border-radius: var(--radius-base); border: none; overflow: hidden;">
        <div class="card-body p-0">
            <table class="table table-hover mb-0">
                <thead style="background-color: var(--color-gray-100); border-bottom: 2px solid #eee;">
                    <tr>
                        <th class="ps-4 py-3" style="width: 100px;">번호</th>
                        <th class="py-3">제목</th>
                        <th class="pe-4 py-3 text-end" style="width: 150px;">작성자</th>
                    </tr>
                </thead>
                <tbody>
                    {{#boardList}}
                    <tr>
                        <td class="ps-4 py-3 align-middle text-muted">{{id}}</td>
                        <td class="py-3 align-middle">
                            <a href="/board/{{id}}" 
                               style="color: var(--color-text-main); text-decoration: none; font-weight: 500;"
                               onmouseover="this.style.color='var(--color-primary)'"
                               onmouseout="this.style.color='var(--color-text-main)'">
                                {{title}}
                            </a>
                        </td>
                        <td class="pe-4 py-3 align-middle text-end text-muted">
                            <span class="badge bg-light text-dark rounded-pill px-3">{{username}}</span>
                        </td>
                    </tr>
                    {{/boardList}}
                    {{^boardList}}
                    <tr>
                        <td colspan="3" class="text-center py-5">
                            <div class="text-muted">
                                <i class="bi bi-journal-x display-4 d-block mb-3"></i>
                                등록된 게시글이 없습니다.
                            </div>
                        </td>
                    </tr>
                    {{/boardList}}
                </tbody>
            </table>
        </div>
    </div>
</div>

{{> layout/footer}}

{{> layout/header}}

<style>
    :root {
        --color-primary: #197fe6;
        --radius-base: 12px;
        --shadow-base: 0 4px 20px rgba(0,0,0,0.05);
        --font-family-base: 'Plus Jakarta Sans', 'Pretendard', sans-serif;
    }

    body {
        font-family: var(--font-family-base);
        background-color: #f8f9fa;
    }

    .join-card {
        border: none;
        border-radius: var(--radius-base);
        box-shadow: var(--shadow-base);
        overflow: hidden;
    }

    .join-card .card-header {
        background-color: var(--color-white);
        border-bottom: 1px solid #eee;
        padding: 1.5rem;
    }

    .join-card .card-body {
        padding: 2rem;
    }

    .form-label {
        font-weight: 500;
        color: #495057;
    }

    .form-control {
        border-radius: 8px;
        padding: 0.6rem 1rem;
        border: 1px solid #dee2e6;
    }

    .form-control:focus {
        border-color: var(--color-primary);
        box-shadow: 0 0 0 0.25rem rgba(25, 127, 230, 0.1);
    }

    .btn-primary {
        background-color: var(--color-primary);
        border: none;
        border-radius: 8px;
        padding: 0.7rem;
        font-weight: 600;
    }

    .btn-outline-primary {
        border-color: var(--color-primary);
        color: var(--color-primary);
        border-radius: 8px;
    }

    .btn-outline-primary:hover {
        background-color: var(--color-primary);
        border-color: var(--color-primary);
    }

    .form-text {
        font-size: 0.85rem;
    }
</style>

<div class="container mt-5 mb-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card join-card">
                <div class="card-header text-center">
                    <h3 class="mb-0">회원가입</h3>
                    <p class="text-muted mt-2">서비스 이용을 위해 정보를 입력해주세요</p>
                </div>
                <div class="card-body">
                    <form action="/join" method="post" onsubmit="return validateForm()">
                        <!-- 아이디 -->
                        <div class="mb-4">
                            <label for="username" class="form-label">아이디</label>
                            <div class="input-group">
                                <input type="text" class="form-control" id="username" name="username" 
                                       placeholder="4~20자 이내" required onchange="resetCheck()">
                                <button class="btn btn-outline-primary px-4" type="button" onclick="checkUsername()">중복확인</button>
                            </div>
                            <div id="username-msg" class="form-text mt-1 text-muted">아이디 중복확인이 필요합니다.</div>
                        </div>

                        <!-- 비밀번호 -->
                        <div class="mb-4">
                            <label for="password" class="form-label">비밀번호</label>
                            <input type="password" class="form-control" id="password" name="password" 
                                   placeholder="비밀번호를 입력하세요" required>
                        </div>

                        <!-- 이메일 -->
                        <div class="mb-4">
                            <label for="email" class="form-label">이메일</label>
                            <input type="email" class="form-control" id="email" name="email" 
                                   placeholder="example@email.com" required>
                        </div>

                        <hr class="my-4">

                        <!-- 주소 (카카오/다음 주소 API) -->
                        <div class="mb-3">
                            <label class="form-label">주소</label>
                            <div class="input-group mb-2">
                                <input type="text" class="form-control" id="postcode" name="postcode" placeholder="우편번호" readonly>
                                <button class="btn btn-outline-secondary" type="button" onclick="execDaumPostcode()">우편번호 찾기</button>
                            </div>
                            <input type="text" class="form-control mb-2" id="address" name="address" placeholder="주소" readonly>
                            <div class="row g-2">
                                <div class="col-6">
                                    <input type="text" class="form-control" id="detailAddress" name="detailAddress" placeholder="상세주소">
                                </div>
                                <div class="col-6">
                                    <input type="text" class="form-control" id="extraAddress" name="extraAddress" placeholder="참고항목" readonly>
                                </div>
                            </div>
                        </div>

                        <div class="d-grid mt-5">
                            <button id="btn-join" class="btn btn-primary" type="submit" disabled>가입하기</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- 다음 우편번호 서비스 스크립트 -->
<script src="//t1.daumcdn.net/mapjsapi/bundle/postcode/prod/postcode.v2.js"></script>
<script>
    let isUsernameChecked = false;

    // 아이디 중복 체크
    async function checkUsername() {
        var username = document.querySelector("#username").value;
        if (!username || username.length < 4) {
            alert("아이디는 4자 이상 입력해주세요.");
            return;
        }

        try {
            var response = await fetch(`/api/user/username-same-check?username=${username}`);
            var result = await response.json();

            if (result.body === true) {
                isUsernameChecked = true;
                document.querySelector("#username-msg").innerText = "사용 가능한 아이디입니다.";
                document.querySelector("#username-msg").classList.remove("text-danger", "text-muted");
                document.querySelector("#username-msg").classList.add("text-success");
                document.querySelector("#btn-join").disabled = false;
            } else {
                isUsernameChecked = false;
                document.querySelector("#username-msg").innerText = "이미 사용 중인 아이디입니다.";
                document.querySelector("#username-msg").classList.remove("text-success", "text-muted");
                document.querySelector("#username-msg").classList.add("text-danger");
                document.querySelector("#btn-join").disabled = true;
            }
        } catch (error) {
            console.error("Error:", error);
            alert("중복 체크 중 오류가 발생했습니다.");
        }
    }

    function resetCheck() {
        isUsernameChecked = false;
        document.querySelector("#username-msg").innerText = "아이디 중복확인이 필요합니다.";
        document.querySelector("#username-msg").classList.remove("text-success", "text-danger");
        document.querySelector("#username-msg").classList.add("text-muted");
        document.querySelector("#btn-join").disabled = true;
    }

    function validateForm() {
        if (!isUsernameChecked) {
            alert("아이디 중복 확인이 필요합니다.");
            return false;
        }
        return true;
    }

    // 다음 주소 API 실행 함수
    function execDaumPostcode() {
        new daum.Postcode({
            oncomplete: function(data) {
                var addr = '';
                var extraAddr = '';

                if (data.userSelectedType === 'R') {
                    addr = data.roadAddress;
                } else {
                    addr = data.jibunAddress;
                }

                if(data.userSelectedType === 'R'){
                    if(data.bname !== '' && /[동|로|가]$/g.test(data.bname)){
                        extraAddr += data.bname;
                    }
                    if(data.buildingName !== '' && data.apartment === 'Y'){
                        extraAddr += (extraAddr !== '' ? ', ' + data.buildingName : data.buildingName);
                    }
                    if(extraAddr !== ''){
                        extraAddr = ' (' + extraAddr + ')';
                    }
                    document.getElementById("extraAddress").value = extraAddr;
                } else {
                    document.getElementById("extraAddress").value = '';
                }

                document.getElementById('postcode').value = data.zonecode;
                document.getElementById("address").value = addr;
                document.getElementById("detailAddress").focus();
            }
        }).open();
    }
</script>

{{> layout/footer}}
